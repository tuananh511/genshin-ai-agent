<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Genshin AI Report — {{ nickname }}</title>
<style>
  body { font-family: 'Segoe UI', sans-serif; max-width: 1100px; margin: 40px auto; padding: 0 20px; background: #0f0f1a; color: #e0e0e0; }
  h1 { color: #c8a96e; border-bottom: 2px solid #c8a96e; padding-bottom: 8px; }
  h2 { color: #7eb8d4; margin-top: 40px; }
  .meta { color: #888; margin-bottom: 30px; }
  table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 0.9em; }
  th { background: #1e1e3a; color: #c8a96e; padding: 8px; text-align: left; }
  td { padding: 6px 8px; border-bottom: 1px solid #2a2a4a; }
  tr:hover { background: #1a1a2e; }
  .card { background: #1a1a2e; border-radius: 8px; padding: 20px; margin: 16px 0; border-left: 4px solid #7eb8d4; }
  .todo { background: #1e1e3a; border-radius: 6px; padding: 12px 16px; margin: 8px 0; }
  .todo .reason { color: #888; font-size: 0.9em; }
  footer { color: #444; text-align: center; margin-top: 60px; font-size: 0.85em; }
</style>
</head>
<body>

<h1>⚔️ Genshin AI Account Manager</h1>
<div class="meta">
  📅 {{ report_date }} &nbsp;|&nbsp;
  👤 {{ nickname }} &nbsp;|&nbsp;
  🏆 AR{{ ar }}
</div>

<h2>📊 Character Score <span style="font-size:0.6em;color:#888;">(xếp theo thứ tự nên build trước)</span></h2>
<table>
  <tr>
    <th>Nhân vật</th><th>Lv</th><th>C</th>
    {% for col in stat_columns %}<th>{{ col }}</th>{% endfor %}
    <th>DMG Bonus</th>
    <th>Vấn đề</th>
  </tr>
  {% for s in scores %}
  <tr>
    <td>{{ s.name }} ({{ s.element }})</td>
    <td>{{ s.level }}</td>
    <td>C{{ s.constellation_count }}</td>
    {% for v in s.stat_values %}<td>{{ v }}</td>{% endfor %}
    <td>{{ s.dmg_bonus }}</td>
    <td>
      {% if s.artifact_issue_count %}{{ s.artifact_issue_count }} artifact chưa +20<br>{% endif %}
      {% if s.low_talent_names %}Cần nâng: {{ s.low_talent_names | join(", ") }}{% endif %}
      {% if not s.artifact_issue_count and not s.low_talent_names %}✅{% endif %}
    </td>
  </tr>
  {% endfor %}
</table>
<p style="color:#666; font-size:0.85em;">Bảng chỉ hiển thị stat thô để đối chiếu — phần phân tích cụ thể với guide nằm ở "Phân tích từ AI" dưới đây.</p>

<h2>🔍 Phân tích từ AI</h2>
<div class="card">{{ llm_advice_html | safe }}</div>
{% if guide_sources %}
<p style="color:#888; font-size:0.85em;">
  Nguồn tham khảo:
  {% for g in guide_sources %}<a href="{{ g.url }}" style="color:#7eb8d4;">{{ g.name }}</a>{% if not loop.last %}, {% endif %}{% endfor %}
</p>
{% endif %}

<h2>🎯 Domain nên farm hôm nay — {{ day_of_week }}</h2>
{% for todo in required_todos %}
<div class="todo">
  <strong>{{ todo.label }}</strong><br>
  <span class="reason">💡 {{ todo.reason }}</span>
</div>
{% endfor %}

<h2>📝 Nhắc nhở thêm <span style="font-size:0.6em;color:#888;">(tuỳ chọn — không liên quan farm)</span></h2>
{% for todo in optional_todos %}
<div class="todo" style="opacity:0.8;">
  <strong>{{ todo.label }}</strong><br>
  <span class="reason">💡 {{ todo.reason }}</span>
</div>
{% endfor %}

<footer>Generated by Genshin AI Agent</footer>
</body>
</html>